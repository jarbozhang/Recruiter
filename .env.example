# === 浏览器驱动 ===
BROWSER_DRIVER=playwright          # playwright / selenium / bb-browser
ADSPOWER_API_KEY=your_api_key_here
ADSPOWER_PROFILE_ID=your_profile_id
ADSPOWER_API_BASE=http://127.0.0.1:50325

# === 数据库 ===
RECRUITER_DB_PATH=data/recruiter.db

# === LLM - 简历匹配（Qwen）===
LLM_MATCH_API_KEY=your_qwen_api_key
LLM_MATCH_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MATCH_MODEL=qwen-plus

# === LLM - 消息生成（Claude）===
LLM_CHAT_API_KEY=your_claude_api_key
LLM_CHAT_BASE_URL=https://api.anthropic.com
LLM_CHAT_MODEL=claude-sonnet-4-20250514

# === 操作频率控制 ===
OP_INTERVAL_MIN=30
OP_INTERVAL_MAX=120
OP_HOURLY_LIMIT=30
OP_DAILY_LIMIT=150

# === 熔断器 ===
CB_FAILURE_THRESHOLD=3
CB_PAUSE_SECONDS=7200

# === 发送超时 ===
SEND_TIMEOUT=60
